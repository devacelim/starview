# ── OpenWeatherMap ────────────────────────────────────────────────────────────
# 발급: https://openweathermap.org/api
# Vercel 대시보드 → Project Settings → Environment Variables 에 등록
# 코드에 절대 직접 포함 금지!
OPENWEATHER_API_KEY=여기에_발급받은_키_입력

# ── Supabase ──────────────────────────────────────────────────────────────────
# 발급: https://supabase.com → Project Settings → API
# SUPABASE_URL      : Project URL  (예: https://abcxyz.supabase.co)
# SUPABASE_ANON_KEY : anon/public key  (프론트엔드 안전 / RLS 적용)
# SUPABASE_SERVICE_KEY : service_role key (시드 스크립트 전용 — 절대 노출 금지)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here  # 로컬 시드 스크립트에만 사용
